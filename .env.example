# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Mock service error injection
# MOCK_ERROR_RATE: 0.0–1.0 random failure rate across all services
MOCK_ERROR_RATE=0.0
# MOCK_FORCE_ERROR: targeted error, e.g. "slack:rate_limit", "jira:not_found", "calendar:timeout"
MOCK_FORCE_ERROR=

# Logging
# LOG_LEVEL: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
# RUNTIME_DIR: directory for runtime logs/audit files
RUNTIME_DIR=runtime
# LOG_FILE: file name or absolute path (default writes to RUNTIME_DIR/agent.log)
LOG_FILE=agent.log
# ENABLE_AUDIT_LOG: true|false
ENABLE_AUDIT_LOG=true
# AUDIT_LOG_FILE: file name or relative path under RUNTIME_DIR
AUDIT_LOG_FILE=audit_events.jsonl
# OpenTelemetry tracing
ENABLE_TRACING=false
TRACING_SERVICE_NAME=react-agent-python
# TRACING_EXPORTER: file | console | otlp
TRACING_EXPORTER=file
# TRACING_FILE: file name or relative path under RUNTIME_DIR
TRACING_FILE=traces.jsonl
# TRACING_OTLP_ENDPOINT: for OTLP/HTTP exporter (e.g. http://localhost:4318/v1/traces)
TRACING_OTLP_ENDPOINT=

# Agent
MAX_AGENT_STEPS=20
# CURRENT_USER: username used by Jira "assign to me", e.g. john.doe
CURRENT_USER=john.doe
DATA_DIR=data
